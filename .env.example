# Environment Variables — Latifia Quraner Alo E-Classroom
# Copy to .env.local and fill in your values. Never commit .env.local.

# ── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Zoom (live classes — Server-to-Server OAuth) ──────────────────────────────
# Create a Server-to-Server OAuth app at: https://marketplace.zoom.us
# Grant scopes: meeting:write:admin, recording:read:admin
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
# From your Zoom app's "Feature" → "Webhooks" tab → Secret Token
ZOOM_WEBHOOK_SECRET_TOKEN=your-zoom-webhook-secret-token

# ── YouTube (recording upload — single institutional channel) ─────────────────
# Google Cloud project: https://console.cloud.google.com
# Enable: YouTube Data API v3
# Create OAuth 2.0 credentials (Desktop app type)
# Generate refresh_token via: node worker/scripts/get-youtube-token.js
YOUTUBE_CLIENT_ID=your-youtube-oauth-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-oauth-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# ── Email alerts (Resend — optional) ─────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@your-domain.com
