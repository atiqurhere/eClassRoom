# Worker Environment Variables
# Copy to .env and fill in your values on Railway

# ── Supabase (service role — required for upload_jobs) ────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Zoom (Server-to-Server OAuth — to download recordings) ───────────────────
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ── YouTube (single institutional channel) ────────────────────────────────────
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# ── Worker tuning (optional) ──────────────────────────────────────────────────
POLL_INTERVAL_MS=30000   # How often to check for new jobs (default: 30s)
MAX_RETRIES=3            # Max attempts before marking a job as 'failed'
